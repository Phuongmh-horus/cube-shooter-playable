      \u0443\u0434\u0430\u043B\u043E\u0441\u044C \u0438\u0437\u043C\u0435\u043D\u0438\u0442\u044C
      \u0438\u043C\u044F!\t\uC774\uB984 \uBCC0\uACBD \uC2E4\uD328!\t\u540D\u524D\u306E\u5909\u66F4\u306B\u5931\u6557\u3057\u307E\u3057\u305F\uFF01\t\u0928\u093E\u092E
      \u092C\u0926\u0932\u0928\u093E \u0935\u093F\u092B\u0932 \u0939\u0941\u0906!\t\u041D\u0435
      \u0432\u0434\u0430\u043B\u043E\u0441\u044F \u0437\u043C\u0456\u043D\u0438\u0442\u0438
      \u0456\u043C\u2019\u044F!\tCambio nome non riuscito!\r\nui_enter_name_space\tEnter
      nickname\tNh\u1EADp bi\u1EC7t danh\tInsira um apelido\tTakma ad girin\tSpitznamen
      eingeben\tEntrez un pseudo\tMasukkan nama panggilan\tIntroduce un apodo\t\u0412\u0432\u0435\u0434\u0438\u0442\u0435
      \u043D\u0438\u043A\t\uB2C9\uB124\uC784 \uC785\uB825\t\u30CB\u30C3\u30AF\u30CD\u30FC\u30E0\u3092\u5165\u529B\t\u0909\u092A\u0928\u093E\u092E
      \u0926\u0930\u094D\u091C \u0915\u0930\u0947\u0902\t\u0412\u0432\u0435\u0434\u0456\u0442\u044C
      \u043D\u0456\u043A\tInserisci nickname\r\nlanguage\tLanguage\tNg\xF4n ng\u1EEF\tIdioma\tDil\tSprache\tLangue\tBahasa\tIdioma\t\u042F\u0437\u044B\u043A\t\uC5B8\uC5B4\t\u8A00\u8A9E\t\u092D\u093E\u0937\u093E\t\u041C\u043E\u0432\u0430\tLingua\r\nui_tut_1\tTap
      to match wool with the box\tCh\u1EA1m v\xE0o len \u0111\u1EC3 n\u1ED1i v\u1EDBi
      h\u1ED9p\tToque para combinar a l\xE3 com a caixa\tY\xFCn\xFC kutuyla e\u015Fle\u015Ftirmek
      i\xE7in dokunun\tTippe, um die Wolle mit der Box abzugleichen\tAppuyez pour
      associer la laine \xE0 la bo\xEEte\tKetuk untuk mencocokkan wol dengan kotak\tToca
      para emparejar la lana con la caja\t\u041D\u0430\u0436\u043C\u0438\u0442\u0435,
      \u0447\u0442\u043E\u0431\u044B \u0441\u043E\u043F\u043E\u0441\u0442\u0430\u0432\u0438\u0442\u044C
      \u0448\u0435\u0440\u0441\u0442\u044C \u0441 \u043A\u043E\u0440\u043E\u0431\u043A\u043E\u0439\t\uC0C1\uC790\uC640
      \uC591\uD138\uC744 \uB9DE\uCD94\uB824\uBA74 \uD0ED\uD558\uC138\uC694\t\u30DC\u30C3\u30AF\u30B9\u306B\u6BDB\u7CF8\u3092\u5408\u308F\u305B\u308B\u306B\u306F\u30BF\u30C3\u30D7\u3057\u3066\u304F\u3060\u3055\u3044\u3002\t\u090A\u0928
      \u0915\u094B \u092C\u0949\u0915\u094D\u0938 \u0938\u0947 \u092E\u093F\u0932\u093E\u0928\u0947
      \u0915\u0947 \u0932\u093F\u090F \u091F\u0948\u092A \u0915\u0930\u0947\u0902\t\u041D\u0430\u0442\u0438\u0441\u043D\u0456\u0442\u044C,
      \u0449\u043E\u0431 \u043F\u043E\u0454\u0434\u043D\u0430\u0442\u0438 \u0432\u043E\u0432\u043D\u0443
      \u0437 \u043A\u043E\u0440\u043E\u0431\u043A\u043E\u044E\tTocca per abbinare
      la lana alla scatola\r\nui_tut_2\tDrag to rotate the object\tK\xE9o \u0111\u1EC3
      xoay v\u1EADt th\u1EC3\tArraste para girar o objeto\tNesneyi d\xF6nd\xFCrmek
      i\xE7in s\xFCr\xFCkle\tZum Drehen des Objekts ziehen\tFaites glisser pour faire
      pivoter l'objet\tSeret untuk memutar objek\tArrastra para rotar el objeto\t\u041F\u0435\u0440\u0435\u0442\u0430\u0449\u0438\u0442\u0435,
      \u0447\u0442\u043E\u0431\u044B \u043F\u043E\u0432\u0435\u0440\u043D\u0443\u0442\u044C
      \u043E\u0431\u044A\u0435\u043A\u0442\t\uAC1C\uCCB4\uB97C \uD68C\uC804\uD558\uB824\uBA74
      \uB4DC\uB798\uADF8\uD558\uC138\uC694\t\u30C9\u30E9\u30C3\u30B0\u3057\u3066\u30AA\u30D6\u30B8\u30A7\u30AF\u30C8\u3092\u56DE\u8EE2\u3057\u3066\u304F\u3060\u3055\u3044\u3002\t\u0935\u0938\u094D\u0924\u0941
      \u0915\u094B \u0918\u0941\u092E\u093E\u0928\u0947 \u0915\u0947 \u0932\u093F\u090F
      \u0916\u0940\u0902\u091A\u0947\u0902\t\u041F\u0435\u0440\u0435\u0442\u044F\u0433\u043D\u0456\u0442\u044C,
      \u0449\u043E\u0431 \u043F\u043E\u0432\u0435\u0440\u043D\u0443\u0442\u0438 \u043E\u0431'\u0454\u043A\u0442\tTrascina
      per ruotare l\u2019oggetto\r\nui_tut_hole\tTap to add hole\tNh\u1EA5n \u0111\u1EC3
      th\xEAm l\u1ED7\tToque para adicionar buraco\tDokunarak delik ekle\tTippen,
      um ein Loch hinzuzuf\xFCgen\tAppuyez pour ajouter un trou\tKetuk untuk menambahkan
      lubang\tToca para agregar un agujero\t\u041D\u0430\u0436\u043C\u0438\u0442\u0435,
      \u0447\u0442\u043E\u0431\u044B \u0434\u043E\u0431\u0430\u0432\u0438\u0442\u044C
      \u043E\u0442\u0432\u0435\u0440\u0441\u0442\u0438\u0435\t\uD0ED\uD558\uC5EC
      \uAD6C\uBA4D \uCD94\uAC00\t\u30BF\u30C3\u30D7\u3067\u7A74\u3092\u8FFD\u52A0\u3067\u304D\u307E\u3059\u3002\t\u091B\u0947\u0926
      \u091C\u094B\u0921\u093C\u0928\u0947 \u0915\u0947 \u0932\u093F\u090F \u091F\u0948\u092A
      \u0915\u0930\u0947\u0902\t\u0422\u043E\u0440\u043A\u043D\u0456\u0442\u044C\u0441\u044F,
      \u0449\u043E\u0431 \u0434\u043E\u0434\u0430\u0442\u0438 \u043E\u0442\u0432\u0456\u0440\tTocca
      per aggiungere un foro\r\nui_tut_broom\tTap to sweep all the wool in the hole
      row\tNh\u1EA5n \u0111\u1EC3 qu\xE9t s\u1EA1ch len trong h\xE0ng l\u1ED7\tToque
      para varrer toda a l\xE3 na linha do buraco\tDokunarak delik s\u0131ras\u0131ndaki
      t\xFCm y\xFCnleri s\xFCp\xFCr\tTippen, um alle Wolle in der Lochreihe zu fegen\tAppuyez
      pour balayer toute la laine dans la rang\xE9e de trous\tKetuk untuk menyapu
      semua wol di baris lubang\tToca para barrer toda la lana en la fila del agujero\t\u041D\u0430\u0436\u043C\u0438\u0442\u0435,
      \u0447\u0442\u043E\u0431\u044B \u0441\u043C\u0435\u0441\u0442\u0438 \u0432\u0441\u044E
      \u0448\u0435\u0440\u0441\u0442\u044C \u0432 \u0440\u044F\u0434\u0443 \u0441
      \u043E\u0442\u0432\u0435\u0440\u0441\u0442\u0438\u044F\u043C\u0438\t\uD0ED\uD558\uC5EC
      \uAD6C\uBA4D \uC904\uC758 \uD138\uC744 \uBAA8\uB450 \uC4F8\uAE30\t\u7A74\u306E\u5217\u306E\u30A6\u30FC\u30EB\u3092\u3059\u3079\u3066\u6383\u9664\u3059\u308B\u306B\u306F\u30BF\u30C3\u30D7\u3057\u3066\u304F\u3060\u3055\u3044\u3002\t\u091B\u0947\u0926
      \u092A\u0902\u0915\u094D\u0924\u093F \u0915\u0940 \u0938\u093E\u0930\u0940
      \u090A\u0928 \u0915\u094B \u0938\u093E\u092B\u093C \u0915\u0930\u0928\u0947
      \u0915\u0947 \u0932\u093F\u090F \u091F\u0948\u092A \u0915\u0930\u0947\u0902\t\u0422\u043E\u0440\u043A\u043D\u0456\u0442\u044C\u0441\u044F,
      \u0449\u043E\u0431 \u0437\u043C\u0456\u0442\u0430\u0442\u0438 \u0432\u0441\u044E
      \u0448\u0435\u0440\u0441\u0442\u044C \u0443 \u0440\u044F\u0434\u0443 \u043E\u0442\u0432\u043E\u0440\u0456\u0432\tTocca
      per spazzare via tutta la lana nella fila di fori\r\nui_tut_rainbowbox\tTap
      to collect three wools of any color\tNh\u1EA5n \u0111\u1EC3 thu th\u1EADp ba
      len c\u1EE7a 1 m\xE0u b\u1EA5t k\xEC\tToque para coletar tr\xEAs l\xE3s de
      qualquer cor\tDokunarak rastgele \xFC\xE7 y\xFCn\xFC topla\tTippen, um drei
      beliebige Wollkn\xE4uel zu sammeln\tAppuyez pour collecter trois laines de
      n\u2019importe quelle couleur\tKetuk untuk mengumpulkan tiga wol warna apa
      saja\tToca para recolectar tres lanas de cualquier color\t\u041D\u0430\u0436\u043C\u0438\u0442\u0435,
      \u0447\u0442\u043E\u0431\u044B \u0441\u043E\u0431\u0440\u0430\u0442\u044C \u0442\u0440\u0438
      \u0448\u0435\u0440\u0441\u0442\u0438 \u043B\u044E\u0431\u043E\u0433\u043E \u0446\u0432\u0435\u0442\u0430\t\uD0ED\uD558\uC5EC
      \uC544\uBB34 \uC0C9\uC758 \uD138 3\uAC1C \uC218\uC9D1\t\u4EFB\u610F\u306E\u8272\u306E\u30A6\u30FC\u30EB\u30923\u3064\u96C6\u3081\u308B\u306B\u306F\u30BF\u30C3\u30D7\u3057\u3066\u304F\u3060\u3055\u3044\u3002\t\u0915\u093F\u0938\u0940
      \u092D\u0940 \u0930\u0902\u0917 \u0915\u0940 \u0924\u0940\u0928 \u090A\u0928
      \u0907\u0915\u091F\u094D\u0920\u093E \u0915\u0930\u0928\u0947 \u0915\u0947
      \u0932\u093F\u090F \u091F\u0948\u092A \u0915\u0930\u0947\u0902\t\u0422\u043E\u0440\u043A\u043D\u0456\u0442\u044C\u0441\u044F,
      \u0449\u043E\u0431 \u0437\u0456\u0431\u0440\u0430\u0442\u0438 \u0442\u0440\u0438
      \u043A\u043B\u0443\u0431\u043A\u0438 \u0448\u0435\u0440\u0441\u0442\u0456 \u0431\u0443\u0434\u044C-\u044F\u043A\u043E\u0433\u043E
      \u043A\u043E\u043B\u044C\u043E\u0440\u0443\tTocca per raccogliere tre gomitoli
      di qualsiasi colore\r\nui_tut_rainbowbox_step2\t\"This color is different!\nTap
      it to fill the rainbow box.\"\t\"M\xE0u n\xE0y kh\xE1c n\xE8! \nCh\u1EA1m \u0111\u1EC3
      cho v\xE0o h\u1ED9p c\u1EA7u v\u1ED3ng.\"\t\"Esta cor \xE9 diferente! \nToque
      para coloc\xE1-la na caixa arco-\xEDris.\"\t\"Bu renk farkl\u0131! \nDokun
      ve g\xF6kku\u015Fa\u011F\u0131 kutusunu doldur.\"\t\"Diese Farbe ist anders!\nTippe,
      um die Regenbogenbox zu f\xFCllen.\"\t\"Cette couleur est diff\xE9rente!\nTouchez
      pour remplir la bo\xEEte arc-en-ciel.\"\t\"Warna ini berbeda!\nKetuk untuk
      mengisi kotak pelangi.\"\t\"Este color es diferente!\nToca para llenar la caja
      arco\xEDris.\"\t\"\u042D\u0442\u043E\u0442 \u0446\u0432\u0435\u0442 \u043E\u0442\u043B\u0438\u0447\u0430\u0435\u0442\u0441\u044F!\n\u041D\u0430\u0436\u043C\u0438\u0442\u0435,
      \u0447\u0442\u043E\u0431\u044B \u0437\u0430\u043F\u043E\u043B\u043D\u0438\u0442\u044C
      \u0440\u0430\u0434\u0443\u0436\u043D\u0443\u044E \u043A\u043E\u0440\u043E\u0431\u043A\u0443.
      \"\t\"\uC774 \uC0C9\uC740 \uB2EC\uB77C\uC694!\n\uBB34\uC9C0\uAC1C \uC0C1\uC790\uC5D0
      \uB123\uC73C\uB824\uBA74 \uD0ED\uD558\uC138\uC694.  \"\t\"\u3053\u306E\u8272\u306F\u9055\u3046\u3088\u3046\u3067\u3059\u3002\n\u30BF\u30C3\u30D7\u3059\u308B\u3068\u8679\u306E\u7BB1\u306B\u5165\u308A\u307E\u3059\u3002\"\t\u092F\u0939
