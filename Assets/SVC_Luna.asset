            u_xlat6.xyz = u_xlat6.xyz * _FakeLightDir.www;\n    u_xlat6.xyz = u_xlat1.xyz
            * u_xlat4.xyz + u_xlat6.xyz;\n    u_xlat2.x = dot(u_xlat6.xyz, vec3(0.212599993,
            0.715200007, 0.0722000003));\n    u_xlat6.xyz = u_xlat6.xyz + (-u_xlat2.xxx);\n   
