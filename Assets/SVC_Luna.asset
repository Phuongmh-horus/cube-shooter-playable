            _Brightness;\nuniform \tfloat _DissolveAmount;\nUNITY_LOCATION(0) uniform
            mediump sampler2D _DissolveMap;\nUNITY_LOCATION(1) uniform mediump sampler2D
            _BaseMap;\nUNITY_LOCATION(2) uniform mediump sampler2D _BumpMap;\nin
            highp vec2 vs_TEXCOORD0;\nin highp vec2 vs_TEXCOORD6;\nin highp vec3
            vs_TEXCOORD1;\nin highp vec3 vs_TEXCOORD3;\nin highp vec3 vs_TEXCOORD4;\nin
            highp vec3 vs_TEXCOORD5;\nlayout(location = 0) out mediump vec4 SV_Target0;\nvec3
            u_xlat0;\nmediump float u_xlat16_0;\nbool u_xlatb0;\nvec4 u_xlat1;\nmediump
            vec4 u_xlat16_1;\nvec4 u_xlat2;\nbool u_xlatb2;\nmediump vec3 u_xlat16_3;\nvec3
            u_xlat4;\nbool u_xlatb4;\nvec3 u_xlat5;\nvec3 u_xlat6;\nbool u_xlatb6;\nvec3
            u_xlat10;\nfloat u_xlat12;\nvec2 u_xlat14;\nmediump vec2 u_xlat16_14;\nbvec2
            u_xlatb14;\nfloat u_xlat18;\nfloat u_xlat20;\nbool u_xlatb20;\nvoid main()\n{\n   
            u_xlatb0 = 0.00100000005<_DissolveAmount;\n    if(u_xlatb0){\n       
            u_xlat16_0 = texture(_DissolveMap, vs_TEXCOORD6.xy).x;\n        u_xlat0.x
            = u_xlat16_0 + (-_DissolveAmount);\n        u_xlatb6 = u_xlat0.x<0.0;\n       
