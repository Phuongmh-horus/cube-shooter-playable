          VertexProgram: "\n#version 100\n\nuniform \tvec3 _WorldSpaceCameraPos;\nuniform
            \tvec4 hlslcc_mtx4x4unity_ObjectToWorld[4];\nuniform \tvec4 hlslcc_mtx4x4unity_WorldToObject[4];\nuniform
            \tvec4 unity_WorldTransformParams;\nuniform \tvec4 hlslcc_mtx4x4unity_MatrixVP[4];\nuniform
            \tvec4 _BaseMap_ST;\nuniform \tvec4 _DissolveMap_ST;\nattribute highp
            vec4 in_POSITION0;\nattribute highp vec3 in_NORMAL0;\nattribute highp
            vec4 in_TANGENT0;\nattribute highp vec2 in_TEXCOORD0;\nvarying highp
            vec2 vs_TEXCOORD0;\nvarying highp vec2 vs_TEXCOORD6;\nvarying highp vec3
            vs_TEXCOORD1;\nvarying highp vec3 vs_TEXCOORD3;\nvarying highp vec3 vs_TEXCOORD4;\nvarying
            highp vec3 vs_TEXCOORD5;\nvec4 u_xlat0;\nvec4 u_xlat1;\nvec3 u_xlat2;\nfloat
            u_xlat9;\nvoid main()\n{\n    vs_TEXCOORD0.xy = in_TEXCOORD0.xy * _BaseMap_ST.xy
            + _BaseMap_ST.zw;\n    vs_TEXCOORD6.xy = in_TEXCOORD0.xy * _DissolveMap_ST.xy
            + _DissolveMap_ST.zw;\n    u_xlat0.x = dot(in_NORMAL0.xyz, hlslcc_mtx4x4unity_WorldToObject[0].xyz);\n   
            u_xlat0.y = dot(in_NORMAL0.xyz, hlslcc_mtx4x4unity_WorldToObject[1].xyz);\n   
            u_xlat0.z = dot(in_NORMAL0.xyz, hlslcc_mtx4x4unity_WorldToObject[2].xyz);\n   
            u_xlat9 = dot(u_xlat0.xyz, u_xlat0.xyz);\n    u_xlat9 = inversesqrt(u_xlat9);\n   
            u_xlat0.xyz = vec3(u_xlat9) * u_xlat0.xyz;\n    vs_TEXCOORD1.xyz = u_xlat0.xyz;\n   
            u_xlat1.xyz = in_TANGENT0.yyy * hlslcc_mtx4x4unity_ObjectToWorld[1].xyz;\n   
            u_xlat1.xyz = hlslcc_mtx4x4unity_ObjectToWorld[0].xyz * in_TANGENT0.xxx
            + u_xlat1.xyz;\n    u_xlat1.xyz = hlslcc_mtx4x4unity_ObjectToWorld[2].xyz
            * in_TANGENT0.zzz + u_xlat1.xyz;\n    u_xlat9 = dot(u_xlat1.xyz, u_xlat1.xyz);\n   
            u_xlat9 = inversesqrt(u_xlat9);\n    u_xlat1.xyz = vec3(u_xlat9) * u_xlat1.xyz;\n   
            vs_TEXCOORD3.xyz = u_xlat1.xyz;\n    u_xlat2.xyz = u_xlat0.zxy * u_xlat1.yzx;\n   
            u_xlat0.xyz = u_xlat0.yzx * u_xlat1.zxy + (-u_xlat2.xyz);\n    u_xlat9
            = in_TANGENT0.w * unity_WorldTransformParams.w;\n    vs_TEXCOORD4.xyz
            = vec3(u_xlat9) * u_xlat0.xyz;\n    u_xlat0 = in_POSITION0.yyyy * hlslcc_mtx4x4unity_ObjectToWorld[1];\n   
            u_xlat0 = hlslcc_mtx4x4unity_ObjectToWorld[0] * in_POSITION0.xxxx + u_xlat0;\n   
            u_xlat0 = hlslcc_mtx4x4unity_ObjectToWorld[2] * in_POSITION0.zzzz + u_xlat0;\n   
            u_xlat1.xyz = hlslcc_mtx4x4unity_ObjectToWorld[3].xyz * in_POSITION0.www
            + u_xlat0.xyz;\n    u_xlat0 = u_xlat0 + hlslcc_mtx4x4unity_ObjectToWorld[3];\n   
            vs_TEXCOORD5.xyz = (-u_xlat1.xyz) + _WorldSpaceCameraPos.xyz;\n    u_xlat1
            = u_xlat0.yyyy * hlslcc_mtx4x4unity_MatrixVP[1];\n    u_xlat1 = hlslcc_mtx4x4unity_MatrixVP[0]
            * u_xlat0.xxxx + u_xlat1;\n    u_xlat1 = hlslcc_mtx4x4unity_MatrixVP[2]
            * u_xlat0.zzzz + u_xlat1;\n    gl_Position = hlslcc_mtx4x4unity_MatrixVP[3]
            * u_xlat0.wwww + u_xlat1;\n    return;\n}\n\n"
          FragmentProgram: "\n#version 100\n\n#ifdef GL_FRAGMENT_PRECISION_HIGH\n   
            precision highp float;\n#else\n    precision mediump float;\n#endif\nprecision
            highp int;\nuniform \tfloat _BumpScale;\nuniform \tfloat _SpecularToonSize;\nuniform
            \tfloat _SpecularToonSmoothness;\nuniform \tfloat _RampThreshold;\nuniform
            \tfloat _RampSmoothing;\nuniform \tfloat _ShadowColorLightAtten;\nuniform
            \tvec4 _FakeLightDir;\nuniform \tvec4 _BaseColor;\nuniform \tvec4 _HColor;\nuniform
            \tvec4 _SColor;\nuniform \tvec4 _SpecularColor;\nuniform \tfloat _DissolveEdgeWidth;\nuniform
            \tvec4 _DissolveEdgeColor;\nuniform \tfloat _Saturation;\nuniform \tfloat
            _Brightness;\nuniform \tfloat _DissolveAmount;\nuniform lowp sampler2D
            _DissolveMap;\nuniform lowp sampler2D _BaseMap;\nuniform lowp sampler2D
            _BumpMap;\nvarying highp vec2 vs_TEXCOORD0;\nvarying highp vec2 vs_TEXCOORD6;\nvarying
            highp vec3 vs_TEXCOORD1;\nvarying highp vec3 vs_TEXCOORD3;\nvarying highp
            vec3 vs_TEXCOORD4;\nvarying highp vec3 vs_TEXCOORD5;\n#define SV_Target0
            gl_FragData[0]\nfloat u_xlat0;\nlowp float u_xlat10_0;\nbool u_xlatb0;\nvec4
            u_xlat1;\nlowp vec4 u_xlat10_1;\nvec4 u_xlat2;\nbool u_xlatb2;\nmediump
            vec2 u_xlat16_3;\nvec3 u_xlat4;\nbool u_xlatb4;\nvec3 u_xlat5;\nvec3
            u_xlat6;\nbool u_xlatb6;\nvec3 u_xlat10;\nfloat u_xlat12;\nvec2 u_xlat14;\nlowp
            vec2 u_xlat10_14;\nbvec2 u_xlatb14;\nfloat u_xlat18;\nfloat u_xlat20;\nbool
            u_xlatb20;\nvoid main()\n{\n    u_xlatb0 = 0.00100000005<_DissolveAmount;\n   
            if(u_xlatb0){\n        u_xlat10_0 = texture2D(_DissolveMap, vs_TEXCOORD6.xy).x;\n       
            u_xlat0 = u_xlat10_0 + (-_DissolveAmount);\n        u_xlatb6 = u_xlat0<0.0;\n       
            if(u_xlatb6){discard;}\n    } else {\n        u_xlat0 = 1.0;\n    }\n   
            u_xlat10_1 = texture2D(_BaseMap, vs_TEXCOORD0.xy);\n    u_xlat1 = u_xlat10_1
            * _BaseColor;\n    u_xlat6.x = dot(vs_TEXCOORD1.xyz, vs_TEXCOORD1.xyz);\n   
            u_xlat6.x = inversesqrt(u_xlat6.x);\n    u_xlat6.xyz = u_xlat6.xxx *
            vs_TEXCOORD1.xyz;\n    u_xlat2.x = dot(vs_TEXCOORD3.xyz, vs_TEXCOORD3.xyz);\n   
            u_xlat2.y = dot(vs_TEXCOORD4.xyz, vs_TEXCOORD4.xyz);\n    u_xlatb14.xy
            = lessThan(vec4(9.99999975e-06, 9.99999975e-06, 9.99999975e-06, 9.99999975e-06),
            u_xlat2.xyxy).xy;\n    u_xlatb14.x = u_xlatb14.y && u_xlatb14.x;\n   
            if(u_xlatb14.x){\n        u_xlat10_14.xy = texture2D(_BumpMap, vs_TEXCOORD0.xy).yw;\n       
            u_xlat16_3.xy = u_xlat10_14.yx * vec2(2.0, 2.0) + vec2(-1.0, -1.0);\n       
            u_xlat14.xy = u_xlat16_3.xy * vec2(_BumpScale);\n        u_xlat4.x =
            dot(u_xlat14.xy, u_xlat14.xy);\n        u_xlat4.x = min(u_xlat4.x, 1.0);\n       
            u_xlat4.x = (-u_xlat4.x) + 1.0;\n        u_xlat4.x = sqrt(u_xlat4.x);\n       
            u_xlat2.x = inversesqrt(u_xlat2.x);\n        u_xlat10.xyz = u_xlat2.xxx
            * vs_TEXCOORD3.xyz;\n        u_xlat2.x = inversesqrt(u_xlat2.y);\n       
            u_xlat5.xyz = u_xlat2.xxx * vs_TEXCOORD4.xyz;\n        u_xlat2.xyw =
            u_xlat14.yyy * u_xlat5.xyz;\n        u_xlat2.xyz = u_xlat14.xxx * u_xlat10.xyz
            + u_xlat2.xyw;\n        u_xlat2.xyz = u_xlat4.xxx * u_xlat6.xyz + u_xlat2.xyz;\n       
            u_xlat20 = dot(u_xlat2.xyz, u_xlat2.xyz);\n        u_xlat20 = inversesqrt(u_xlat20);\n       
            u_xlat6.xyz = vec3(u_xlat20) * u_xlat2.xyz;\n    }\n    u_xlat2.x = dot(_FakeLightDir.xyz,
            _FakeLightDir.xyz);\n    u_xlat2.x = inversesqrt(u_xlat2.x);\n    u_xlat2.xyz
            = u_xlat2.xxx * _FakeLightDir.xyz;\n    u_xlat20 = dot(u_xlat6.xyz, u_xlat2.xyz);\n   
            u_xlat20 = u_xlat20 * 0.5 + 0.5;\n    u_xlat4.x = (-_RampSmoothing) *
            0.5 + _RampThreshold;\n    u_xlat10.x = _RampSmoothing * 0.5 + _RampThreshold;\n   
            u_xlat10.x = (-u_xlat4.x) + u_xlat10.x;\n    u_xlat20 = u_xlat20 + (-u_xlat4.x);\n   
            u_xlat4.x = float(1.0) / u_xlat10.x;\n    u_xlat20 = u_xlat20 * u_xlat4.x;\n   
            u_xlat20 = clamp(u_xlat20, 0.0, 1.0);\n    u_xlat4.x = u_xlat20 * -2.0
            + 3.0;\n    u_xlat20 = u_xlat20 * u_xlat20;\n    u_xlat20 = u_xlat20
            * u_xlat4.x;\n    u_xlatb4 = _ShadowColorLightAtten<0.5;\n    u_xlat10.xyz
            = _FakeLightDir.www * _HColor.xyz;\n    u_xlat4.xyz = (bool(u_xlatb4))
            ? u_xlat10.xyz : _HColor.xyz;\n    u_xlat4.xyz = u_xlat4.xyz + (-_SColor.xyz);\n   
            u_xlat4.xyz = vec3(u_xlat20) * u_xlat4.xyz + _SColor.xyz;\n    u_xlatb20
            = _ShadowColorLightAtten>=0.5;\n    u_xlat5.xyz = u_xlat4.xyz * _FakeLightDir.www;\n   
            u_xlat4.xyz = (bool(u_xlatb20)) ? u_xlat5.xyz : u_xlat4.xyz;\n    u_xlat20
            = dot(vs_TEXCOORD5.xyz, vs_TEXCOORD5.xyz);\n    u_xlat20 = inversesqrt(u_xlat20);\n   
            u_xlat2.xyz = vs_TEXCOORD5.xyz * vec3(u_xlat20) + u_xlat2.xyz;\n    u_xlat20
            = dot(u_xlat2.xyz, u_xlat2.xyz);\n    u_xlat20 = inversesqrt(u_xlat20);\n   
            u_xlat2.xyz = vec3(u_xlat20) * u_xlat2.xyz;\n    u_xlat6.x = dot(u_xlat6.xyz,
            u_xlat2.xyz);\n    u_xlat6.x = clamp(u_xlat6.x, 0.0, 1.0);\n    u_xlat12
            = (-_SpecularToonSize) + 1.0;\n    u_xlat12 = max(u_xlat12, 0.0);\n   
            u_xlat12 = min(u_xlat12, 0.999000013);\n    u_xlat18 = (-u_xlat12) +
            1.0;\n    u_xlat2.x = float(1.0) / u_xlat18;\n    u_xlat12 = u_xlat12
            / u_xlat18;\n    u_xlat6.x = u_xlat6.x * u_xlat2.x + (-u_xlat12);\n   
            u_xlat6.x = clamp(u_xlat6.x, 0.0, 1.0);\n    u_xlat12 = max(_SpecularToonSmoothness,
            9.99999975e-05);\n    u_xlat12 = float(1.0) / u_xlat12;\n    u_xlat6.x
            = u_xlat12 * u_xlat6.x;\n    u_xlat6.x = min(u_xlat6.x, 1.0);\n    u_xlat12
            = u_xlat6.x * -2.0 + 3.0;\n    u_xlat6.x = u_xlat6.x * u_xlat6.x;\n   
            u_xlat6.x = u_xlat6.x * u_xlat12;\n    u_xlat6.xyz = u_xlat6.xxx * _SpecularColor.xyz;\n   
            u_xlat6.xyz = u_xlat6.xyz * _FakeLightDir.www;\n    u_xlat6.xyz = u_xlat1.xyz
            * u_xlat4.xyz + u_xlat6.xyz;\n    u_xlat2.x = dot(u_xlat6.xyz, vec3(0.212599993,
            0.715200007, 0.0722000003));\n    u_xlat6.xyz = u_xlat6.xyz + (-u_xlat2.xxx);\n   
            u_xlat6.xyz = vec3(_Saturation) * u_xlat6.xyz + u_xlat2.xxx;\n    u_xlat2.x
            = float(1.0) / _DissolveEdgeWidth;\n    u_xlat0 = u_xlat0 * u_xlat2.x;\n   
            u_xlat0 = clamp(u_xlat0, 0.0, 1.0);\n    u_xlat2.x = u_xlat0 * -2.0 +
            3.0;\n    u_xlat0 = u_xlat0 * u_xlat0;\n    u_xlat0 = (-u_xlat2.x) *
            u_xlat0 + 1.0;\n    u_xlatb2 = _DissolveAmount>=0.00100000005;\n    u_xlat2.x
            = u_xlatb2 ? 1.0 : float(0.0);\n    u_xlat0 = u_xlat0 * u_xlat2.x;\n   
            u_xlat2.xyz = vec3(u_xlat0) * _DissolveEdgeColor.xyz;\n    u_xlat2.xyz
            = u_xlat2.xyz * _DissolveEdgeColor.www;\n    u_xlat1.xyz = u_xlat6.xyz
            * vec3(vec3(_Brightness, _Brightness, _Brightness)) + u_xlat2.xyz;\n   
            SV_Target0 = u_xlat1;\n    return;\n}\n\n"
