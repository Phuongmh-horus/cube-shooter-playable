            u_xlat16_1 = texture(_BaseMap, vs_TEXCOORD0.xy);\n    u_xlat1 = u_xlat16_1
            * _BaseColor;\n    u_xlat6.x = dot(vs_TEXCOORD1.xyz, vs_TEXCOORD1.xyz);\n   
            u_xlat6.x = inversesqrt(u_xlat6.x);\n    u_xlat6.xyz = u_xlat6.xxx *
            vs_TEXCOORD1.xyz;\n    u_xlat2.x = dot(vs_TEXCOORD3.xyz, vs_TEXCOORD3.xyz);\n   
            u_xlat2.y = dot(vs_TEXCOORD4.xyz, vs_TEXCOORD4.xyz);\n    u_xlatb14.xy
            = lessThan(vec4(9.99999975e-05, 9.99999975e-05, 9.99999975e-05, 9.99999975e-05),
            u_xlat2.xyxy).xy;\n    u_xlatb14.x = u_xlatb14.y && u_xlatb14.x;\n   
            if(u_xlatb14.x){\n        u_xlat16_14.xy = texture(_BumpMap, vs_TEXCOORD0.xy).yw;\n       
            u_xlat16_3.xy = u_xlat16_14.yx * vec2(2.0, 2.0) + vec2(-1.0, -1.0);\n       
            u_xlat14.xy = u_xlat16_3.xy * vec2(_BumpScale);\n        u_xlat4.x =
            dot(u_xlat14.xy, u_xlat14.xy);\n        u_xlat4.x = min(u_xlat4.x, 1.0);\n       
            u_xlat4.x = (-u_xlat4.x) + 1.0;\n        u_xlat4.x = sqrt(u_xlat4.x);\n       
            u_xlat2.x = inversesqrt(u_xlat2.x);\n        u_xlat10.xyz = u_xlat2.xxx
            * vs_TEXCOORD3.xyz;\n        u_xlat2.x = inversesqrt(u_xlat2.y);\n       
            u_xlat5.xyz = u_xlat2.xxx * vs_TEXCOORD4.xyz;\n        u_xlat2.xyw =
            u_xlat14.yyy * u_xlat5.xyz;\n        u_xlat2.xyz = u_xlat14.xxx * u_xlat10.xyz
            + u_xlat2.xyw;\n        u_xlat2.xyz = u_xlat4.xxx * u_xlat6.xyz + u_xlat2.xyz;\n       
            u_xlat20 = dot(u_xlat2.xyz, u_xlat2.xyz);\n        u_xlat20 = inversesqrt(u_xlat20);\n       
            u_xlat6.xyz = vec3(u_xlat20) * u_xlat2.xyz;\n    }\n    u_xlat2.x = dot(_FakeLightDir.xyz,
            _FakeLightDir.xyz);\n    u_xlat2.x = inversesqrt(u_xlat2.x);\n    u_xlat2.xyz
            = u_xlat2.xxx * _FakeLightDir.xyz;\n    u_xlat20 = dot(u_xlat6.xyz, u_xlat2.xyz);\n   
