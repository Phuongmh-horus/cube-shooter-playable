            vs_TEXCOORD1.xyz;\n    u_xlat2.x = dot(vs_TEXCOORD3.xyz, vs_TEXCOORD3.xyz);\n   
            u_xlat2.y = dot(vs_TEXCOORD4.xyz, vs_TEXCOORD4.xyz);\n    u_xlatb14.xy
            = lessThan(vec4(9.99999975e-05, 9.99999975e-05, 9.99999975e-05, 9.99999975e-05),
            u_xlat2.xyxy).xy;\n    u_xlatb14.x = u_xlatb14.y && u_xlatb14.x;\n   
            if(u_xlatb14.x){\n        u_xlat16_14.xy = texture(_BumpMap, vs_TEXCOORD0.xy).yw;\n       
