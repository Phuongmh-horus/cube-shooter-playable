            = log2(u_xlat16_3.x);\n    u_xlat16_3.x = u_xlat16_3.x * unity_SpecCube0_HDR.y;\n   
            u_xlat16_3.x = exp2(u_xlat16_3.x);\n    u_xlat16_3.x = u_xlat16_3.x *
            unity_SpecCube0_HDR.x;\n    u_xlat16_3.xyz = u_xlat10_1.xyz * u_xlat16_3.xxx;\n   
