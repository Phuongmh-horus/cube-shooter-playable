            0.0, 1.0);\n    u_xlat16_3.x = u_xlat16_0 * -2.0 + 3.0;\n    u_xlat16_0
            = u_xlat16_0 * u_xlat16_0;\n    u_xlat16_0 = u_xlat16_0 * u_xlat16_3.x;\n   
