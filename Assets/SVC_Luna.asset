            u_xlat4.xyz = (bool(u_xlatb20)) ? u_xlat5.xyz : u_xlat4.xyz;\n    u_xlat20
            = dot(vs_TEXCOORD5.xyz, vs_TEXCOORD5.xyz);\n    u_xlat20 = inversesqrt(u_xlat20);\n   
            u_xlat2.xyz = vs_TEXCOORD5.xyz * vec3(u_xlat20) + u_xlat2.xyz;\n    u_xlat20
            = dot(u_xlat2.xyz, u_xlat2.xyz);\n    u_xlat20 = inversesqrt(u_xlat20);\n   
            u_xlat2.xyz = vec3(u_xlat20) * u_xlat2.xyz;\n    u_xlat6.x = dot(u_xlat6.xyz,
            u_xlat2.xyz);\n    u_xlat6.x = clamp(u_xlat6.x, 0.0, 1.0);\n    u_xlat12
            = (-_SpecularToonSize) + 1.0;\n    u_xlat12 = max(u_xlat12, 0.0);\n   
            u_xlat12 = min(u_xlat12, 0.999000013);\n    u_xlat18 = (-u_xlat12) +
            1.0;\n    u_xlat2.x = float(1.0) / u_xlat18;\n    u_xlat12 = u_xlat12
            / u_xlat18;\n    u_xlat6.x = u_xlat6.x * u_xlat2.x + (-u_xlat12);\n   
            u_xlat6.x = clamp(u_xlat6.x, 0.0, 1.0);\n    u_xlat12 = max(_SpecularToonSmoothness,
            9.99999975e-05);\n    u_xlat12 = float(1.0) / u_xlat12;\n    u_xlat6.x
            = u_xlat12 * u_xlat6.x;\n    u_xlat6.x = min(u_xlat6.x, 1.0);\n    u_xlat12
            = u_xlat6.x * -2.0 + 3.0;\n    u_xlat6.x = u_xlat6.x * u_xlat6.x;\n   
