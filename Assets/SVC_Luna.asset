            1.0);\n    u_xlat16_14 = (-u_xlat16_14) + 1.0;\n    u_xlat16_3.x = vs_TEXCOORD2.y
            + vs_TEXCOORD2.y;\n    u_xlat16_3.x = float(1.0) / u_xlat16_3.x;\n   
            u_xlat16_14 = u_xlat16_14 * u_xlat16_3.x;\n    u_xlat16_14 = clamp(u_xlat16_14,
            0.0, 1.0);\n    u_xlat16_3.x = u_xlat16_14 * -2.0 + 3.0;\n    u_xlat16_14
            = u_xlat16_14 * u_xlat16_14;\n    u_xlat16_14 = u_xlat16_14 * u_xlat16_3.x;\n   
            u_xlat16_14 = u_xlat16_14 * 0.5;\n    u_xlat16_14 = u_xlat1.w * u_xlat16_14;\n   
            u_xlat16_14 = u_xlat16_14 * vs_TEXCOORD2.w;\n    u_xlat16_3.xyz = u_xlat16_2.xyz
            * vec3(10.0, 10.0, 10.0) + vec3(-1.0, -1.0, -1.0);\n    u_xlat16_3.xyz
            = vs_TEXCOORD3.yyy * u_xlat16_3.xyz + vec3(1.0, 1.0, 1.0);\n    SV_Target0.xyz
            = vec3(u_xlat16_14) * u_xlat16_3.xyz + u_xlat16_2.xyz;\n    return;\n}\n\n"
