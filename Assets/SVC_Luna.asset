            vec4 u_xlat16_1;\nvec4 u_xlat2;\nbvec4 u_xlatb2;\nmediump vec3 u_xlat16_3;\nvoid
            main()\n{\n    u_xlat16_0 = (-vs_TEXCOORD3.x) + vs_TEXCOORD2.x;\n   
            u_xlat16_0 = u_xlat16_0 / vs_TEXCOORD2.z;\n    u_xlat16_0 = min(abs(u_xlat16_0),
            1.0);\n    u_xlat16_0 = (-u_xlat16_0) + 1.0;\n    u_xlat16_3.x = vs_TEXCOORD2.y
            + vs_TEXCOORD2.y;\n    u_xlat16_3.x = float(1.0) / u_xlat16_3.x;\n   
